{
  "name": "server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc",
    "start": "bun run dist/index.js",
    "buckets:setup": "bun run src/scripts/infrastructure/setup-buckets.ts",
    "buckets:reset": "bun run src/scripts/infrastructure/reset-buckets.ts",
    "cloudfront:setup": "bun run src/scripts/infrastructure/setup-cloudfront.ts",
    "cloudfront:reset": "bun run src/scripts/infrastructure/reset-cloudfront.ts",
    "db:reset": "bun run src/scripts/infrastructure/reset-db.ts",
    "db:setup": "bun run src/scripts/infrastructure/setup-db.ts",
    "infra:reset": "bun run db:reset && bun run lambda:reset && bun run buckets:reset && bun run cloudfront:reset",
    "infra:setup": "bun run db:setup && bun run buckets:setup && bun run lambda:deploy && bun run cloudfront:setup",
    "lambda:build": "bun run src/scripts/deployment/build-lambda.ts",
    "lambda:deploy": "bun run src/scripts/deployment/deploy-lambda.ts",
    "lambda:reset": "bun run src/scripts/infrastructure/reset-lambda.ts",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1017.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1018.0",
    "@aws-sdk/client-iam": "^3.1017.0",
    "@aws-sdk/client-lambda": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
