# AWS S3 Configuration (Names must be globally unique)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_BUCKET_NAME_IMAGES=dynamic-image-tx-uploads-2026
AWS_BUCKET_NAME_TRANSFORMED=dynamic-image-tx-transformed-2026
AWS_REGION=us-east-1
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Database Configuration
DATABASE_URL="postgresql://user:pass@host:port/db?sslmode=verify-full"

# Application Configuration
PORT=3001

# Security Configuration
SIGNING_SECRET=your_32_character_hmac_secret

# --- AUTOMATED INFRASTRUCTURE ---
# Managed by `bun run infra:setup`. Manual changes may be overwritten.
AWS_LAMBDA_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME
AWS_LAMBDA_FUNCTION_URL=https://FUNCTION_ID.lambda-url.REGION.on.aws/
CLOUDFRONT_DISTRIBUTION_ID=DISTRIBUTION_ID
CLOUDFRONT_DOMAIN=DISTRIBUTION_ID.cloudfront.net
