{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "start": "node dist/index.js",
    "dev": "tsc-watch --onSuccess \"node dist/index.js\"",
    "build": "tsc -p .",
    "buckets:setup": "tsx src/scripts/infrastructure/setup-buckets.ts",
    "buckets:reset": "tsx src/scripts/infrastructure/reset-buckets.ts",
    "cloudfront:setup": "tsx src/scripts/infrastructure/setup-cloudfront.ts",
    "cloudfront:reset": "tsx src/scripts/infrastructure/reset-cloudfront.ts",
    "db:reset": "tsx src/scripts/infrastructure/reset-db.ts",
    "db:setup": "tsx src/scripts/infrastructure/setup-db.ts",
    "infra:reset": "pnpm run db:reset && pnpm run lambda:reset && pnpm run buckets:reset && pnpm run cloudfront:reset",
    "infra:setup": "pnpm run db:setup && pnpm run buckets:setup && pnpm run lambda:deploy && pnpm run cloudfront:setup",
    "lambda:build": "tsx src/scripts/deployment/build-lambda.ts",
    "lambda:deploy": "tsx src/scripts/deployment/deploy-lambda.ts",
    "lambda:reset": "tsx src/scripts/infrastructure/reset-lambda.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1017.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1018.0",
    "@aws-sdk/client-iam": "^3.1017.0",
    "@aws-sdk/client-lambda": "^3.1017.0",
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/winston": "^2.4.4",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
